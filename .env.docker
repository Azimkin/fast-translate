# Docker Environment Configuration
# Copy this file to .env.docker and customize for your deployment

# ============================================
# Ollama Configuration
# ============================================

# Required: Ollama API endpoint
# For Docker, use host.docker.internal to access Ollama on the host machine
# Or use another container name if running Ollama in a separate container
OLLAMA_API_ENDPOINT=http://host.docker.internal:11434

# Optional: Ollama authentication token (if your Ollama instance requires auth)
OLLAMA_AUTH_TOKEN=

# ============================================
# Server Configuration
# ============================================

# Port the application will listen on inside the container
PORT=4321

# ============================================
# CORS Configuration
# ============================================

# Allowed origins for cross-origin requests (comma-separated)
# Use '*' for development, specify domains for production
# Example: TRANSLATE_ALLOWED_ORIGINS=https://example.com,https://app.example.com
TRANSLATE_ALLOWED_ORIGINS=*

# ============================================
# Optional: Run Ollama in a separate container
# ============================================

# If you want to run Ollama in Docker alongside fast-translate:
# 1. Uncomment the ollama service in docker-compose.yml
# 2. Change OLLAMA_API_ENDPOINT to: http://ollama:11434
