# ============================================
# Fast Translate - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ============================================
# Ollama Configuration (Required)
# ============================================

# Ollama API endpoint (REQUIRED)
# The URL where your Ollama API is accessible
# Examples:
#   Local: http://localhost:11434
#   Docker: http://host.docker.internal:11434
#   Remote: http://your-server.com:11434
OLLAMA_API_ENDPOINT=http://localhost:11434

# ============================================
# Ollama Authentication (Optional)
# ============================================
# Choose ONE of the following authentication methods:

# Option 1: Bearer Token Authentication
# If set, this token will be sent as a Bearer token in the Authorization header
# Example: Authorization: Bearer my-secret-token
OLLAMA_AUTH_TOKEN=

# Option 2: HTTP Basic Authentication
# If both username and password are set, they take precedence over the auth token
# The credentials will be sent as: Authorization: Basic base64(username:password)
OLLAMA_USERNAME=
OLLAMA_PASSWORD=

# Leave all authentication fields empty if your Ollama instance doesn't require auth

# ============================================
# CORS Configuration (Optional)
# ============================================

# Allowed origins for the translation endpoint (OPTIONAL)
# Comma-separated list of allowed origins for cross-origin requests
# Default: * (allows all origins)
# For production, specify your domain(s):
#   TRANSLATE_ALLOWED_ORIGINS=https://example.com,https://app.example.com
TRANSLATE_ALLOWED_ORIGINS=*

# Allowed origins for the CSRF token endpoint (OPTIONAL)
# Comma-separated list of allowed origins for cross-origin requests
# Default: * (allows all origins)
# For production, specify your domain(s):
#   CSRF_ALLOWED_ORIGINS=https://example.com,https://app.example.com
CSRF_ALLOWED_ORIGINS=*

# ============================================
# Model Configuration (Optional)
# ============================================

# Allowed models for translation (OPTIONAL)
# Comma-separated list of allowed Ollama models
# Default: empty (allows all models)
# Examples:
#   TRANSLATE_ALLOWED_MODELS=translategemma:latest,llama3.2
#   TRANSLATE_ALLOWED_MODELS=qwen3.5:4b,mistral-small3.2:latest
# Leave empty to allow any model
TRANSLATE_ALLOWED_MODELS=

# ============================================
# Server Configuration (Optional)
# ============================================

# Server port (OPTIONAL, used in Docker/production)
# Default: 4321
# PORT=4321
