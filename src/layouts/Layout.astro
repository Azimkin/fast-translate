---
/**
 * Layout.astro
 * 
 * Base layout component with theme system integration.
 * - Includes global CSS styles with mint-lime green color palette
 * - Applies theme attribute to HTML element for CSS custom properties
 * - Includes inline script for instant theme application (prevents FOUC)
 * - Provides slot for page content
 */

interface Props {
  /** Page title */
  title?: string;
  /** Additional meta description */
  description?: string;
  /** Additional classes for the body element */
  bodyClass?: string;
}

const { 
  title = 'Fast Translate', 
  description = 'Fast and accurate translations powered by AI',
  bodyClass = ''
} = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="light">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		
		<!-- Theme System: Inline script to prevent Flash of Unstyled Content (FOUC) -->
		<!-- This runs before any CSS/JS loads to apply the correct theme immediately -->
		<script is:inline>
			{`
				(function() {
					const THEME_KEY = 'fast-translate-theme';
					const html = document.documentElement;
					
					// Get stored theme or system preference
					function getInitialTheme() {
						const stored = localStorage.getItem(THEME_KEY);
						if (stored === 'light' || stored === 'dark') {
							return stored;
						}
						// Check system preference
						if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
							return 'dark';
						}
						return 'light';
					}
					
					// Apply theme immediately
					const theme = getInitialTheme();
					html.setAttribute('data-theme', theme);
				})();
			`}
		</script>
		
		<title>{title}</title>
	</head>
	<body class={bodyClass}>
		<!-- Skip to main content link for accessibility -->
		<a href="#main-content" class="skip-link">Skip to main content</a>
		
		<slot />
		
		<!-- Global Styles -->
		<style is:global>
			@import '../styles/global.css';
		</style>
	</body>
</html>
